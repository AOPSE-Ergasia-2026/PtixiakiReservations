@model PtixiakiReservations.Models.ViewModels.VenueViewModel

@{
    ViewData["Title"] = "Edit";
    var allCategoriesChecked = Model.SelectedEventTypeIds?.Any() != true;
}

<div class="container mx-auto p-6">
    <div class="bg-white p-6 shadow-lg rounded-md">
        <h4 class="text-xl font-semibold text-gray-700 mb-4">Venue Details</h4>
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
            <input asp-for="Id" type="hidden"/>

            <!-- Name Field -->
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input asp-for="Name"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
            </div>

            <!-- Address Field -->
            <div>
                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">Address</label>
                <input asp-for="Address"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="Address" class="text-red-500 text-sm"></span>
            </div>

            <!-- Venue Category Field -->
            <div>
                <div class="flex items-center gap-5 mb-2">
                    <label for="CategoriesSelect" class="block text-sm font-medium text-gray-700">
                        Supported Event Types
                    </label>
                    <label class="flex items-center gap-2 text-sm font-medium text-gray-700" for="categoryCheckBox">
                        <input type="checkbox"
                               class="size-4"
                               id="categoryCheckBox"
                               @(allCategoriesChecked ? "checked" : "")>
                        All Categories?
                    </label>
                </div>
                <select asp-for="SelectedEventTypeIds"
                        asp-items="ViewBag.EventTypes"
                        multiple="multiple"
                        id="CategoriesSelect"
                        class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50 h-32">
                </select>
                <span asp-validation-for="SelectedEventTypeIds" class="text-red-500 text-sm"></span>
            </div>

            <!-- City Field -->
            <div>
                <label asp-for="CityId" class="block text-sm font-medium text-gray-700 mb-1">City</label>
                <select asp-for="CityId"
                        asp-items="ViewBag.ListOfCity"
                        class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50">
                </select>
                <span asp-validation-for="CityId" class="text-red-500 text-sm"></span>
            </div>

            <!-- Postal Code Field -->
            <div>
                <label asp-for="PostalCode" class="block text-sm font-medium text-gray-700 mb-1">Postal Code</label>
                <input asp-for="PostalCode"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="PostalCode" class="text-red-500 text-sm"></span>
            </div>

            <!-- Phone Field -->
            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input asp-for="Phone"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="Phone" class="text-red-500 text-sm"></span>
            </div>

            <!-- Venue URL Field -->
            <div>
                <label asp-for="VenueUrl" class="block text-sm font-medium text-gray-700 mb-1">Venue URL</label>
                <input asp-for="VenueUrl"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="VenueUrl" class="text-red-500 text-sm"></span>
            </div>

            <!-- Social Media URL Field -->
            <div>
                <label asp-for="SocialMediaUrl" class="block text-sm font-medium text-gray-700 mb-1">Social Media URL</label>
                <input asp-for="SocialMediaUrl"
                       class="block w-full px-3 py-2 border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-base text-gray-700 rounded-sm bg-gray-50"/>
                <span asp-validation-for="SocialMediaUrl" class="text-red-500 text-sm"></span>
            </div>

            <!-- Photo Upload -->
            <div>
                <label for="file_input" class="block text-sm font-medium text-gray-700 mb-1">Photo Upload</label>
                <div class="mt-1 flex items-center">
                    <input asp-for="Photo"
                           class="block w-full text-sm text-gray-900 border border-gray-300 rounded-sm cursor-pointer bg-gray-50 focus:outline-none focus:border-blue-500"
                           id="file_input" type="file">
                    <span asp-validation-for="Photo" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <!-- Submit Button -->
            <div>
                <input type="submit" value="Save"
                       class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-sm shadow-md hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"/>
            </div>
        </form>
    </div>
</div>
<!-- Back to List -->
<div class="mt-6">
    <a asp-action="Index"
       class="text-blue-600 hover:underline text-sm font-medium">
        Back to List
    </a>
</div>

@if (ViewBag.SelectedValue != null)
{
    <div class="mt-4 text-sm text-gray-600">
        Selected City: <span class="font-semibold">@ViewBag.SelectedValue</span>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fileInput = document.querySelector('#file_input');
            const categoryCheckBox = document.getElementById("categoryCheckBox");
            const selectCategories = document.getElementById("CategoriesSelect");

            function categoryOptions() {
                return Array.from(selectCategories.options);
            }

            function setAllCategories(checked) {
                categoryCheckBox.checked = checked;
                selectCategories.disabled = checked;

                if (checked) {
                    categoryOptions().forEach(option => option.selected = false);
                }
            }

            function updateAllCategoriesState() {
                const options = categoryOptions();
                const allSelected = options.length > 0 && options.every(option => option.selected);

                if (allSelected) {
                    setAllCategories(true);
                } else {
                    categoryCheckBox.checked = false;
                }
            }

            categoryCheckBox.addEventListener("change", function () {
                setAllCategories(categoryCheckBox.checked);
            });

            selectCategories.addEventListener("mousedown", function (event) {
                if (selectCategories.disabled || event.target.tagName !== "OPTION") {
                    return;
                }

                event.preventDefault();
                event.target.selected = !event.target.selected;
                selectCategories.focus();
                updateAllCategoriesState();
            });

            selectCategories.addEventListener("change", updateAllCategoriesState);

            if (categoryCheckBox.checked) {
                setAllCategories(true);
            } else {
                updateAllCategoriesState();
            }

            fileInput.addEventListener("change", function () {
                const fileName = this.value.split("\\").pop();
                this.nextElementSibling.innerText = fileName;
            });
        });
    </script>
}

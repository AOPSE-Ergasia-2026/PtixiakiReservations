@using PtixiakiReservations.Models
@model IEnumerable<PtixiakiReservations.Models.City>
@{
    ViewData["Title"] = "Manage Cities";
}

<div class="container mx-auto px-4">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">All Cities</h1>
    <table class="min-w-full bg-white rounded-lg shadow-md overflow-hidden">
            <thead class="bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
            <tr>
                <th class="py-3 px-6 text-left">City Name</th>
                <th class="py-3 px-6 text-center">City ID</th>
                <th class="py-3 px-20 text-center">Actions</th>
            </tr>
            </thead>
            <tbody class="text-gray-600 text-sm font-light">
            @foreach (var item in Model)
            {
                <tr class="border-b border-gray-200 hover:bg-gray-100">
                    <td class="py-3 px-6 text-left">
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td class="py-3 px-6 text-center">
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td class="py-3 px-6 text-center">
                        <a href="@Url.Action("EditCity","City",new { CityId = item.Id })" class="text-blue-600 hover:underline">Edit</a>
                        <form asp-action="DeleteCity" asp-controller="City" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this City?');" class="inline">
                        <button type="submit" class="text-red-600 hover:underline">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
    </table>
    <div class="container max auto px-4 py-5 text-left">
        <a href="@Url.Action("CreateCity","City")" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">Add New</a>
    </div>
</div>
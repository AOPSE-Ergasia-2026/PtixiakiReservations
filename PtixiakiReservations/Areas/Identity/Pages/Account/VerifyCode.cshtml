@page
@model PtixiakiReservations.Areas.Identity.Pages.Account.VerifyCodeModel

@{
    ViewData["Title"] = "Verificiation";
}

<div class="container mx-auto mt-10 px-4">
    <div class="flex justify-center">
        <div class="w-full max-w-md">
            <section class="bg-white p-6 rounded-lg shadow-md">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" asp-for="Input.RememberMe" />

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="123456" />
                        <label asp-for="Input.Code">Security Code</label>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    
                    <button type="submit" class="w-100 btn btn-lg btn-primary">Verify and Log in</button>
                </form>
            </section>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</div>
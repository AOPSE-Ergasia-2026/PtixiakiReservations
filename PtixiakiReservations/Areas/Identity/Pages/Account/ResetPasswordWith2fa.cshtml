@page
@model ResetPasswordWith2faModel
@{
    ViewData["Title"] = "2FA Verification Required";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <p class="text-info">Your account has 2FA enabled. Please enter the 6-digit code to confirm your password change.</p>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label>Verification Code</label>
                    <input name="TwoFactorCode" class="form-control" autocomplete="off" required />
                </div>
                <button type="submit" class="btn btn-primary">Verify & Reset Password</button>
            </form>
        </div>
    </div>
</div>
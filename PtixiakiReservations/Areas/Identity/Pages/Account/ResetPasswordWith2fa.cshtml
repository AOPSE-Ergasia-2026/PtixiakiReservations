@page
@model ResetPasswordWith2faModel
@{
    ViewData["Title"] = "2FA Verification Required";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <p class="text-info">Your account has 2FA enabled. Please enter the 6-digit code to confirm your password change.</p>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label>Verification Code</label>
                    <input name="TwoFactorCode" class="form-control block w-full mt-1 px-4 py-2 border border-gray-300 rounded-lg 
                                        focus:ring focus:ring-blue-200 focus:outline-none pr-10
                                        transition-all duration-200" autocomplete="off" required />
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 focus:ring focus:ring-blue-200 transition duration-200">Verify & Reset Password</button>
            </form>
        </div>
    </div>
</div>